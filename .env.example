# Paprika account credentials (required)
PAPRIKA_EMAIL=you@example.com
PAPRIKA_PASSWORD=your-password

# --- MCP server transport (optional) ---
# Unset → stdio (local, Claude Desktop). Allowed values: stdio | http
# MCP_TRANSPORT=http

# HTTP mode only (ignored in stdio mode)
# MCP_HOST=127.0.0.1    # default (fail-closed); set to this machine's LAN IP to serve the network
# MCP_PORT=8000         # default; must be 1-65535

# Do NOT set FASTMCP_* variables here. FastMCP reads this same .env file
# with prefix FASTMCP_, and those keys become live framework config that
# bypasses this project's resolver.

# --- RESERVED for per-device auth (Piece 3) — documented only, not yet loaded ---
# MCP_API_KEY_<DEVICE_NAME>=<token>
